# Configuration locale du site Maintenant!.
#
# Copier ce fichier en `.env.local` (non commité) et remplir les valeurs.
# Tout ce qui est préfixé NEXT_PUBLIC_ est exposé côté client : n'y mettre
# QUE des clés publiques. Tout le reste reste strictement serveur.
#
# Convention pour les services externes (cf. CLAUDE.md §6) : chaque service
# a une variable *_PROVIDER (ou équivalent) qui choisit entre le mock par
# défaut et l'implémentation réelle. Le site fonctionne à 100 % en local
# sans aucune clé d'API.

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Maintenant!
NODE_ENV=development

# --- Supabase (chantier 1.1) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Jeton API Management (https://supabase.com/dashboard/account/tokens), requis
# UNIQUEMENT par scripts/appliquer-sql-distant.ts pour appliquer du SQL au distant
# quand la CLI `supabase` n'est pas disponible. Jamais exposé côté client.
SUPABASE_ACCESS_TOKEN=

# --- Email (Brevo / Mock) ---
# Valeurs : `mock` (défaut, pas de clé requise) ou `brevo`.
EMAIL_PROVIDER=mock
BREVO_API_KEY=
BREVO_SMTP_USER=
BREVO_SMTP_PASS=
BREVO_NEWSLETTER_LIST_ID=

# --- Paiements (Stripe / Mock) ---
# Valeurs : `mock` (défaut), `stripe_test`, `stripe_live`.
PAYMENT_PROVIDER=mock
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# --- T99CP (Polygon / Mock) ---
# Valeurs : `mock` (défaut), `mumbai`, `polygon_mainnet`.
T99CP_NETWORK=mock
NEXT_PUBLIC_T99CP_CONTRACT_ADDRESS=0x7275cfc83f486d53ca1379fc1f8025490bdcc79a
T99CP_RPC_URL=
# Clé privée du wallet trésorerie : chiffrée au repos, jamais en clair en prod.
T99CP_TRESORERIE_WALLET_PRIVATE_KEY=

# --- LiveKit (visio Décider, chantier 7.6) ---
# Valeurs : `mock` (défaut), `livekit`.
LIVEKIT_PROVIDER=mock
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Cloudflare Turnstile (anti-bot, tous formulaires publics) ---
# Valeurs : `mock` (défaut), `cloudflare`.
# Le composant client `<CaptchaTurnstile>` lit aussi NEXT_PUBLIC_TURNSTILE_PROVIDER
# pour décider s'il monte le widget Cloudflare ou retourne un token mock.
TURNSTILE_PROVIDER=mock
NEXT_PUBLIC_TURNSTILE_PROVIDER=mock
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- AzuraCast (Maintenant Radio, chantier 7.2) ---
NEXT_PUBLIC_AZURACAST_URL=

# --- Image Storage (cycle V2, ET2) ---
# Valeurs : `mock` (défaut), `supabase`.
# `mock` : data URL en mémoire, fonctionne sans aucun setup. Idéal en dev/test.
# `supabase` : bucket `media` Supabase Storage. Provisionné par la migration
#   `20260526220000_storage_media_bucket.sql`, à appliquer avec `supabase db push`.
IMAGE_STORAGE_PROVIDER=mock
